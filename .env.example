# 確定申告自動化ツール - 環境変数設定テンプレート
# このファイルをコピーして .env にリネームし、実際の値を設定してください。
# $ cp .env.example .env

# ============================================================
# Gemini API キー (必須 - Gemini分類を使う場合)
# ============================================================
# Google AI Studio で取得: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# オプション設定
# ============================================================

# 使用するGeminiモデル (デフォルト: gemini-2.5-flash)
# gemini-2.5-flash : 無料枠あり・高速・低コスト (推奨・デフォルト)
#                    無料枠: 1日20リクエスト / 月1回処理なら十分
# gemini-2.5-pro   : より高精度・有料のみ (無料枠なし)
# GEMINI_MODEL=gemini-2.5-flash

# キャッシュファイルの場所 (デフォルト: cache/gemini_cache.json)
# CACHE_FILE=cache/gemini_cache.json

# ログレベル (DEBUG / INFO / WARNING / ERROR)
# LOG_LEVEL=INFO
